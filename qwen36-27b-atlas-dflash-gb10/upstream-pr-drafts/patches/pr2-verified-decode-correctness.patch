+    fn ensure_projected_context_cache(
+        &self,
+        dstate: &mut DflashProposerState,
+        ctx: &ForwardContext,
+        stream: u64,
+    ) -> Result<()> {
+        use crate::layers::ops;
+
+        if dstate.ctx_proj_len > dstate.ctx_len {
+            dstate.ctx_proj_len = 0;
+            dstate.ctx_kv_len = 0;
+        }
+        let start = dstate.ctx_proj_len;
+        let rows = dstate.ctx_len.saturating_sub(start);
+        let bf16 = 2usize;
+        let target_hidden_dim = self.target_layer_ids.len() * self.target_hidden_size;
+        let expected_ctx_slot = target_hidden_dim * bf16;
+        let expected_proj_slot = self.hidden_size * bf16;
+        let kv_dim = self.num_kv_heads * self.head_dim;
+        let expected_kv_slot = kv_dim * bf16;
+        let expected_kv_stride = dstate.max_ctx_len * expected_kv_slot * 2;
+        if dstate.ctx_slot_bytes != expected_ctx_slot
+            || dstate.ctx_proj_slot_bytes != expected_proj_slot
+            || dstate.ctx_kv_slot_bytes != expected_kv_slot
+            || dstate.ctx_kv_layer_stride_bytes != expected_kv_stride
+        {
+            bail!("DFlash projected-context cache slot size mismatch");
+        }
+
+        if rows > 0 {
+            let dst = dstate
+                .ctx_proj_acc
+                .offset(start * dstate.ctx_proj_slot_bytes);
+            let src = dstate.ctx_hidden_acc.offset(start * dstate.ctx_slot_bytes);
+            if rows == 1 {
+                ops::dense_gemv(
+                    ctx.gpu,
+                    self.kernels.dense_gemv,
+                    src,
+                    &self.fc,
+                    dst,
+                    self.hidden_size as u32,
+                    target_hidden_dim as u32,
+                    stream,
+                )?;
+            } else {
+                ops::dense_gemm(
+                    ctx.gpu,
+                    self.kernels.dense_gemm,
+                    src,
+                    &self.fc,
+                    dst,
+                    rows as u32,
+                    self.hidden_size as u32,
+                    target_hidden_dim as u32,
+                    stream,
+                )?;
+            }
+            ops::rms_norm(
+                ctx.gpu,
+                self.kernels.rms_norm,
+                dst,
+                &self.hidden_norm,
+                dst,
+                rows as u32,
+                self.hidden_size as u32,
+                self.rms_norm_eps,
+                stream,
+            )?;
+            dstate.ctx_proj_len = dstate.ctx_len;
+        }
+
+        if dstate.ctx_kv_len > dstate.ctx_proj_len {
+            dstate.ctx_kv_len = 0;
+        }
+        let mut kv_start = dstate.ctx_kv_len;
+        while kv_start < dstate.ctx_proj_len {
+            let rows_left = dstate.ctx_proj_len - kv_start;
+            let chunk_rows = rows_left.min(self.ctx_window.max(1));
+            let pos_host: Vec<i32> = (kv_start..kv_start + chunk_rows)
+                .map(|p| p as i32)
+                .collect();
+            let pos_bytes: Vec<u8> = pos_host.iter().flat_map(|p| p.to_le_bytes()).collect();
+            ctx.gpu.copy_h2d(&pos_bytes, self.scratch.position_ids)?;
+            ctx.gpu.memset(
+                self.scratch.q_buf,
+                0,
+                chunk_rows * self.num_q_heads * self.head_dim * bf16,
+            )?;
+            let proj_src = dstate
+                .ctx_proj_acc
+                .offset(kv_start * dstate.ctx_proj_slot_bytes);
+            for (layer_idx, layer) in self.layers.iter().enumerate() {
+                let layer_base =
+                    dstate.ctx_kv_acc.offset(layer_idx * dstate.ctx_kv_layer_stride_bytes);
+                let k_dst = layer_base.offset(kv_start * dstate.ctx_kv_slot_bytes);
+                let v_dst = layer_base.offset(
+                    dstate.max_ctx_len * dstate.ctx_kv_slot_bytes
+                        + kv_start * dstate.ctx_kv_slot_bytes,
+                );
+                ops::dense_gemm(
+                    ctx.gpu,
+                    self.kernels.dense_gemm,
+                    proj_src,
+                    &layer.k_proj,
+                    k_dst,
+                    chunk_rows as u32,
+                    kv_dim as u32,
+                    self.hidden_size as u32,
+                    stream,
+                )?;
+                ops::dense_gemm(
+                    ctx.gpu,
+                    self.kernels.dense_gemm,
+                    proj_src,
+                    &layer.v_proj,
+                    v_dst,
+                    chunk_rows as u32,
+                    kv_dim as u32,
+                    self.hidden_size as u32,
+                    stream,
+                )?;
+                ops::rms_norm(
+                    ctx.gpu,
+                    self.kernels.rms_norm,
+                    k_dst,
+                    &layer.k_norm,
+                    k_dst,
+                    chunk_rows as u32 * self.num_kv_heads as u32,
+                    self.head_dim as u32,
+                    self.rms_norm_eps,
+                    stream,
+                )?;
+                if self.rope_uses_yarn {
+                    ops::rope_yarn(
+                        ctx.gpu,
+                        self.kernels.rope_qwen3,
+                        self.scratch.q_buf,
+                        k_dst,
+                        self.scratch.position_ids,
+                        chunk_rows as u32,
+                        self.num_q_heads as u32,
+                        self.num_kv_heads as u32,
+                        self.head_dim as u32,
+                        self.rotary_dim as u32,
+                        self.yarn_inv_freq,
+                        self.rope_theta,
+                        stream,
+                    )?;
+                } else {
+                    ops::rope(
+                        ctx.gpu,
+                        self.kernels.rope_qwen3,
+                        self.scratch.q_buf,
+                        k_dst,
+                        self.scratch.position_ids,
+                        chunk_rows as u32,
+                        self.num_q_heads as u32,
+                        self.num_kv_heads as u32,
+                        self.head_dim as u32,
+                        self.rotary_dim as u32,
+                        self.rope_theta,
+                        stream,
+                    )?;
+                }
+            }
+            kv_start += chunk_rows;
+            dstate.ctx_kv_len = kv_start;
+        }
+        static LOGGED: std::sync::atomic::AtomicBool = std::sync::atomic::AtomicBool::new(false);
+        if !LOGGED.swap(true, std::sync::atomic::Ordering::Relaxed) {
+            tracing::info!(
+                "DFlash projected ctx/KV cache active: lazy fc+hidden_norm and per-layer K/V for newly committed rows"
+            );
+        }
+        Ok(())
+    }
+}
+
+fn append_latest_context_capture(
+    dstate: &mut DflashProposerState,
+    ctx: &ForwardContext,
+    stream: u64,
+    target_hidden_stack: Option<DevicePtr>,
+    position: usize,
+) -> Result<()> {
+    // The correct DFlash loop appends all committed verifier rows after
+    // verification resolves, not a single stale "latest" row immediately
+    // before proposing. Keep the old path behind an opt-in diagnostic flag
+    // so existing row-dump/debug scripts can still force it when needed.
+    let legacy_decode_append = std::env::var("ATLAS_DFLASH_LEGACY_DECODE_APPEND")
+        .ok()
+        .as_deref()
+        == Some("1");
+    let append_bootstrap_row = !legacy_decode_append
+        && target_hidden_stack.is_some()
+        && dstate.ctx_len < position
+        && dstate.ctx_len + 1 == position;
+    if !legacy_decode_append && !append_bootstrap_row {
+        static LOGGED: std::sync::atomic::AtomicBool = std::sync::atomic::AtomicBool::new(false);
+        if !LOGGED.swap(true, std::sync::atomic::Ordering::Relaxed) {
+            tracing::info!(
+                "DFlash committed-row ctx carry active: legacy latest-row append disabled"
+            );
+        }
+        return Ok(());
+    }
+    if let Some(latest_ctx) = target_hidden_stack
+        && dstate.ctx_len < dstate.max_ctx_len
+    {
+        let dst_offset = dstate.ctx_len * dstate.ctx_slot_bytes;
+        ctx.gpu.copy_d2d_async(
+            latest_ctx,
+            dstate.ctx_hidden_acc.offset(dst_offset),
+            dstate.ctx_slot_bytes,
+            stream,
+        )?;
+        dstate.ctx_len += 1;
+        if append_bootstrap_row {
+            static LOGGED: std::sync::atomic::AtomicBool =
+                std::sync::atomic::AtomicBool::new(false);
+            if !LOGGED.swap(true, std::sync::atomic::Ordering::Relaxed) {
+                tracing::info!(
+                    "DFlash bootstrap ctx alignment active: appended committed bootstrap row before first proposal"
+                );
+            }
+        }
+    }
+    Ok(())
 }
