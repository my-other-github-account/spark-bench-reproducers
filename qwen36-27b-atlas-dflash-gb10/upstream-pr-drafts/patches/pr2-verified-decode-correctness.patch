-        // Phase 1: no real KV trim because `propose()` is a stub. Phase 2
-        // adds the rollback that drops `(last_num_drafted - num_accepted)`
-        // tokens from each layer's paged cache.
-        let _ = num_accepted;
+        if dstate.pending_ctx_rows > 0 {
+            // Reference DFlash keeps target-hidden context for the current
+            // block's row 0 plus accepted draft rows, then crops away the
+            // rejected/future rows. The bonus token is only the next row-0
+            // embedding, so its hidden is not appended yet.
+            let keep_rows = (num_accepted + 1).min(dstate.pending_ctx_rows);
+            let new_len = dstate
+                .pending_ctx_start
+                .saturating_add(keep_rows)
+                .min(dstate.max_ctx_len);
+            dstate.ctx_len = new_len;
+            if dstate.ctx_proj_len > dstate.ctx_len {
+                dstate.ctx_proj_len = dstate.ctx_len;
+            }
+            if dstate.ctx_kv_len > dstate.ctx_len {
+                dstate.ctx_kv_len = dstate.ctx_len;
+            }
+            dstate.pending_ctx_start = 0;
+            dstate.pending_ctx_rows = 0;
+        }
         dstate.last_num_drafted = 0;
         Ok(())
     }
 
-    fn free_state(&self, _state: &mut dyn ProposerState) -> Result<()> {
-        // Phase 1: nothing to free (no allocated KV blocks yet). Phase 2
-        // reclaims paged blocks across all drafter layers.
+    fn free_state(
+        &self,
+        state: &mut dyn ProposerState,
+        gpu: &dyn spark_runtime::gpu::GpuBackend,
+    ) -> Result<()> {
+        let dstate = state
+            .as_any_mut()
+            .downcast_mut::<DflashProposerState>()
+            .ok_or_else(|| anyhow::anyhow!("Invalid DFlash proposer state"))?;
+        let mut first_error = None;
+        let mut free_owned = |name: &str, ptr: &mut DevicePtr| {
+            if ptr.0 == 0 {
+                return;
+            }
+            let owned = *ptr;
+            if let Err(e) = gpu.free(owned) {
+                tracing::error!("DFlash free_state: gpu.free({name}={owned:?}): {e:#}");
+                if first_error.is_none() {
+                    first_error = Some(e);
+                }
+            }
+            *ptr = DevicePtr(0);
+        };
+        free_owned("ctx_hidden_acc", &mut dstate.ctx_hidden_acc);
+        free_owned("ctx_proj_acc", &mut dstate.ctx_proj_acc);
+        free_owned("ctx_kv_acc", &mut dstate.ctx_kv_acc);
+        dstate.block_table.clear();
+        dstate.seq_len = 0;
+        dstate.ctx_len = 0;
+        dstate.ctx_proj_len = 0;
+        dstate.ctx_kv_len = 0;
+        dstate.pending_ctx_start = 0;
+        dstate.pending_ctx_rows = 0;
+        if let Some(e) = first_error {
+            return Err(e);
+        }
         Ok(())
     }
 }
