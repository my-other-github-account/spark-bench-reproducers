+/// W4A16 GEMM with transposed weight rows padded to `n_stride`.
+///
+/// Computes real output width `n`, but reads the transposed NVFP4 weight and
+/// scale matrices with `n_stride` as their row stride. This keeps cp.async
+/// source addresses aligned for vocab sizes that are not multiples of 16/128.
+#[allow(clippy::too_many_arguments)]
+pub fn w4a16_gemm_n128_strided(
+    gpu: &dyn GpuBackend,
+    kernel: KernelHandle,
+    input: DevicePtr,
+    weight: &QuantizedWeight,
+    output: DevicePtr,
+    m: u32,
+    n: u32,
+    k: u32,
+    n_stride: u32,
+    stream: u64,
+) -> Result<()> {
+    KernelLaunch::new(gpu, kernel)
+        .grid([div_ceil(n, 128), div_ceil(m, 64), 1])
+        .block([128, 1, 1])
+        .arg_ptr(input)
+        .arg_ptr(weight.weight)
+        .arg_ptr(weight.weight_scale)
+        .arg_f32(weight.weight_scale_2)
+        .arg_ptr(output)
+        .arg_u32(m)
+        .arg_u32(n)
+        .arg_u32(k)
+        .arg_u32(n_stride)
+        .launch(stream)
+}
+
 /// W4A16 GEMM v3: MiniMax-only shadow with K_STEP=64 (was 32 in v2).
 /// Halves K-iteration count; doubles per-iter MMA count. 1 CTA/SM
 /// (was 3 for v2) due to larger SMEM footprint.
diff --git a/crates/spark-model/src/layers/ops/prefill_attn_main_a.rs b/crates/spark-model/src/layers/ops/prefill_attn_main_a.rs
index 9427b5f..89e541d 100644
--- a/crates/spark-model/src/layers/ops/prefill_attn_main_a.rs
+++ b/crates/spark-model/src/layers/ops/prefill_attn_main_a.rs
@@ -59,6 +59,51 @@ pub fn prefill_attention(
         .launch(stream)
 }
 
+/// DFlash contiguous attention: γ query rows attend over `ctx + γ` K/V rows.
+///
+/// This is the non-paged counterpart of the DFlash paged dispatcher. The
+/// query pointer is the start of the γ noise rows; K/V point at the full
+/// `[ctx, noise]` buffer. `q_offset` is the logical position of query row 0
+/// inside that K/V sequence, used for sliding-window masking.
+#[allow(clippy::too_many_arguments)]
+pub fn prefill_attention_qkv(
+    gpu: &dyn GpuBackend,
+    kernel: KernelHandle,
+    q: DevicePtr,
+    k: DevicePtr,
+    v: DevicePtr,
+    output: DevicePtr,
+    q_len: u32,
+    kv_len: u32,
+    q_offset: u32,
+    num_q_heads: u32,
+    num_kv_heads: u32,
+    head_dim: u32,
+    inv_sqrt_d: f32,
+    causal: bool,
+    sliding_window: u32,
+    stream: u64,
+) -> Result<()> {
+    let br = if head_dim > 256 { 16u32 } else { 32u32 };
+    KernelLaunch::new(gpu, kernel)
+        .grid([num_q_heads, div_ceil(q_len, br), 1])
+        .block([128, 1, 1])
+        .arg_ptr(q)
+        .arg_ptr(k)
+        .arg_ptr(v)
+        .arg_ptr(output)
+        .arg_u32(q_len)
+        .arg_u32(kv_len)
+        .arg_u32(q_offset)
+        .arg_u32(num_q_heads)
+        .arg_u32(num_kv_heads)
+        .arg_u32(head_dim)
+        .arg_f32(inv_sqrt_d)
+        .arg_u32(if causal { 1 } else { 0 })
+        .arg_u32(sliding_window)
+        .launch(stream)
+}
+
