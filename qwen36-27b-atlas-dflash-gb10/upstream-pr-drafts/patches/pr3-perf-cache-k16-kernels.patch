+    /// Transpose weight layout from `[N, K/2]` to `[K/2, N_STRIDE]`.
+    ///
+    /// `n_stride` must be at least `n` and should be aligned for vectorized
+    /// GEMM loads. Padded columns are zero-filled so tail tiles can still use
+    /// aligned 16-byte copies while callers write only the real `n` columns.
+    pub fn transpose_for_gemm_padded(
+        &self,
+        gpu: &dyn GpuBackend,
+        n: usize,
+        k: usize,
+        n_stride: usize,
+    ) -> Result<QuantizedWeight> {
+        const GROUP_SIZE: usize = 16;
+        ensure!(n_stride >= n, "n_stride must be >= n");
+        ensure!(
+            n_stride % 16 == 0,
+            "n_stride must be 16-byte aligned for cp.async GEMM loads"
+        );
+        let half_k = k / 2;
+
+        let packed_size = n * half_k;
+        let mut buf = vec![0u8; packed_size];
+        gpu.copy_d2h(self.weight, &mut buf)?;
+        let mut t_buf = vec![0u8; n_stride * half_k];
+        for i in 0..n {
+            for j in 0..half_k {
+                t_buf[j * n_stride + i] = buf[i * half_k + j];
+            }
+        }
+        let new_weight = gpu.alloc(t_buf.len())?;
+        gpu.copy_h2d(&t_buf, new_weight)?;
+
+        let num_groups = k / GROUP_SIZE;
+        let scale_size = n * num_groups;
+        let mut sbuf = vec![0u8; scale_size];
+        gpu.copy_d2h(self.weight_scale, &mut sbuf)?;
+        let mut st_buf = vec![0u8; n_stride * num_groups];
+        for i in 0..n {
+            for j in 0..num_groups {
+                st_buf[j * n_stride + i] = sbuf[i * num_groups + j];
+            }
+        }
+        let new_scale = gpu.alloc(st_buf.len())?;
+        gpu.copy_h2d(&st_buf, new_scale)?;
+
+        Ok(QuantizedWeight {
+            weight: new_weight,
+            weight_scale: new_scale,
+            weight_scale_2: self.weight_scale_2,
+            input_scale: self.input_scale,
+        })
+    }
