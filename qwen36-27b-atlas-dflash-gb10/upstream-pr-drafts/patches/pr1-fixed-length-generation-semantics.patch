diff --git a/crates/spark-server/src/scheduler/helpers.rs b/crates/spark-server/src/scheduler/helpers.rs
index c0caa80..792f81a 100644
--- a/crates/spark-server/src/scheduler/helpers.rs
+++ b/crates/spark-server/src/scheduler/helpers.rs
@@ -126,6 +126,19 @@ pub fn enable_loop_watchdog() -> bool {
     *ENABLE_LOOP_WATCHDOG.get().unwrap_or(&false)
 }
 
+/// True while the caller still owes the request its declared minimum
+/// completion length. Setting `min_tokens == max_tokens` is Atlas' explicit
+/// fixed-length generation contract.
+#[inline]
+pub fn token_target_pending(output_tokens: usize, min_tokens: usize) -> bool {
+    output_tokens < min_tokens
+}
+
+#[inline]
+pub fn loop_watchdog_allowed(output_tokens: usize, min_tokens: usize) -> bool {
+    !token_target_pending(output_tokens, min_tokens)
+}
+
 /// F2 (2026-04-26): cap on free-text tokens between successive
 /// `<tool_call>` opens when `tool_choice="auto"`. The grammar FSM
 /// in `auto` mode (grammar.rs:461-462) sets `at_least_one=false`
@@ -402,4 +415,18 @@ mod thinking_loop_tests {
             "two repeats in content must not trigger (need 3)"
         );
     }
+
+    #[test]
+    fn token_target_is_pending_until_min_tokens() {
+        assert!(token_target_pending(0, 128));
+        assert!(token_target_pending(127, 128));
+        assert!(!token_target_pending(128, 128));
+        assert!(!token_target_pending(129, 128));
+    }
+
+    #[test]
+    fn loop_watchdog_waits_for_fixed_length_target() {
+        assert!(!loop_watchdog_allowed(64, 128));
+        assert!(loop_watchdog_allowed(128, 128));
+    }
 }
