+            s[0] = s[1];
+            s[1] = s[2];
+            s[2] = s[3];
+            s[3] = new_val;
+
+            float* inter = conv_state_intermediates
+                + (unsigned long long)t * intermediate_stride_floats
+                + ch * d_conv;
+            #pragma unroll
+            for (unsigned int k = 0; k < 4; k++) {
+                if (k < d_conv) inter[k] = s[k];
+            }
+
+            float acc = b_val;
+            #pragma unroll
+            for (unsigned int k = 0; k < 4; k++) {
+                if (k < d_conv) acc += s[k] * w_reg[k];
+            }
+            const float sigmoid_acc = 1.0f / (1.0f + __expf(-acc));
+            silu = acc * sigmoid_acc;
+        }
+
+        if (block_needs_l2) {
+            float sq = (valid && active_t) ? (silu * silu) : 0.0f;
+            const unsigned int warp_id = tid / 32;
+            const unsigned int lane = tid % 32;
+            for (int offset = 16; offset >= 1; offset >>= 1) {
+                sq += __shfl_down_sync(0xFFFFFFFF, sq, offset);
+            }
+
+            __shared__ float warp_sums[8];
+            if (lane == 0) warp_sums[warp_id] = sq;
+            __syncthreads();
+
+            const unsigned int head_in_block = tid / head_dim;
+            const unsigned int base_warp = head_in_block * (head_dim / 32);
+            if (tid == 0 || tid == head_dim) {
+                float total = warp_sums[base_warp] + warp_sums[base_warp + 1]
+                            + warp_sums[base_warp + 2] + warp_sums[base_warp + 3];
+                warp_sums[base_warp] = rsqrtf(total + l2_eps);
+            }
+            __syncthreads();
+
+            if (valid && active_t) {
+                silu *= warp_sums[base_warp];
+            }
+        }
+
+        if (valid && active_t) {
+            output[(unsigned long long)t * output_stride + ch] = __float2bfloat16(silu);
+        }
+        __syncthreads();
+    }
+
+    if (valid) {
+        float* state = conv_state + ch * d_conv;
+        #pragma unroll
+        for (unsigned int k = 0; k < 4; k++) {
+            if (k < d_conv) state[k] = s[k];
+        }
+    }
+}
