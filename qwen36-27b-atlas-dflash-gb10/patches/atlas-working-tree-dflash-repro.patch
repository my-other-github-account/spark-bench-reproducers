+
+    if (valid) {
+        float* state = conv_state + ch * d_conv;
+        const __nv_bfloat16* w = weight + ch * d_conv;
+        #pragma unroll
+        for (unsigned int k = 0; k < 4; k++) {
+            if (k < d_conv) {
+                s[k] = state[k];
+                w_reg[k] = (float)w[k];
+            }
+        }
+    }
+
+    for (unsigned int t = 0; t < 16; t++) {
+        const bool active_t = t < seq_len;
+        float silu = 0.0f;
+
+        if (valid && active_t) {
