+
+fn append_latest_context_capture(
+    dstate: &mut DflashProposerState,
+    ctx: &ForwardContext,
+    stream: u64,
+    target_hidden_stack: Option<DevicePtr>,
+    position: usize,
+) -> Result<()> {
+    // The correct DFlash loop appends all committed verifier rows after
+    // verification resolves, not a single stale "latest" row immediately
+    // before proposing. Keep the old path behind an opt-in diagnostic flag
+    // so existing row-dump/debug scripts can still force it when needed.
+    let legacy_decode_append = std::env::var("ATLAS_DFLASH_LEGACY_DECODE_APPEND")
+        .ok()
+        .as_deref()
+        == Some("1");
+    let append_bootstrap_row = !legacy_decode_append
+        && target_hidden_stack.is_some()
+        && dstate.ctx_len < position
+        && dstate.ctx_len + 1 == position;
+    if !legacy_decode_append && !append_bootstrap_row {
+        static LOGGED: std::sync::atomic::AtomicBool = std::sync::atomic::AtomicBool::new(false);
+        if !LOGGED.swap(true, std::sync::atomic::Ordering::Relaxed) {
+            tracing::info!(
+                "DFlash committed-row ctx carry active: legacy latest-row append disabled"
+            );
+        }
+        return Ok(());
+    }
+    if let Some(latest_ctx) = target_hidden_stack
+        && dstate.ctx_len < dstate.max_ctx_len
+    {
+        let dst_offset = dstate.ctx_len * dstate.ctx_slot_bytes;
+        ctx.gpu.copy_d2d_async(
+            latest_ctx,
+            dstate.ctx_hidden_acc.offset(dst_offset),
+            dstate.ctx_slot_bytes,
+            stream,
+        )?;
+        dstate.ctx_len += 1;
+        if append_bootstrap_row {
+            static LOGGED: std::sync::atomic::AtomicBool =
+                std::sync::atomic::AtomicBool::new(false);
+            if !LOGGED.swap(true, std::sync::atomic::Ordering::Relaxed) {
+                tracing::info!(
+                    "DFlash bootstrap ctx alignment active: appended committed bootstrap row before first proposal"
+                );
+            }
+        }
+    }
+    Ok(())
 }
