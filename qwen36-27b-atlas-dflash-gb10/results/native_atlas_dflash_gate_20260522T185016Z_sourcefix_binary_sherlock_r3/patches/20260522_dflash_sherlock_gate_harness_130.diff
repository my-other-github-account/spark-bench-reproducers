+#!/usr/bin/env bash
+set -euo pipefail
+
+ROOT=${ROOT:-/home/banana_bae/qwen36_genuine_ddtree_dflash_30pct_goal_20260519_130950}
+ATLAS_DIR=${ATLAS_DIR:-$ROOT/refs/atlas}
+STAMP=${STAMP:-$(date -u +%Y%m%dT%H%M%SZ)}
+OUT=${OUT:-$ROOT/native_atlas_dflash_gate_$STAMP}
+IMAGE=${IMAGE:-atlas-gb10:qwen36-27b-dflash-gate-$STAMP}
+DOCKER_TARGET=${DOCKER_TARGET:-builder}
+SPARK_BIN=${SPARK_BIN:-/build/target/release/spark}
+
+MODEL_PATH=${MODEL_PATH:-/home/banana_bae/models/Qwen3.6-27B-NVFP4-unsloth}
