+
+PORT=${PORT:-18080}
+PROXY_PORT=${PROXY_PORT:-18180}
+RUNS=${RUNS:-3}
+BENCHY_RUNS=${BENCHY_RUNS:-3}
+TG=${TG:-128}
+PP=${PP:-2048}
