+    --api-key [REDACTED]
+    --model "$MODEL_NAME"
+    --served-model-name "$MODEL_NAME"
+    --pp "$PP"
+    --tg "$TG"
+    --depth 0
+    --concurrency 1
+    --runs "$BENCHY_RUNS"
