+echo "started $(date -Is) host=$(hostname) out=$OUT"
+echo "root=$ROOT atlas=$ATLAS_DIR image=$IMAGE docker_target=$DOCKER_TARGET spark_bin=$SPARK_BIN"
+
+SERVER_CONTAINER=""
+PROXY_PID=""
+
+cleanup_proxy() {
+  set +e
+  if [[ -n "${PROXY_PID:-}" ]] && kill -0 "$PROXY_PID" 2>/dev/null; then
+    kill "$PROXY_PID" 2>/dev/null
+    sleep 1
+    kill -9 "$PROXY_PID" 2>/dev/null
+  fi
+  PROXY_PID=""
+  set -e
+}
+
+cleanup_server() {
+  set +e
+  if [[ -n "${SERVER_CONTAINER:-}" ]]; then
+    docker logs "$SERVER_CONTAINER" > "$OUT/logs/${SERVER_CONTAINER}_final.log" 2>&1 || true
+    docker rm -f "$SERVER_CONTAINER" >/dev/null 2>&1 || true
+  fi
+  SERVER_CONTAINER=""
+  set -e
+}
+
+cleanup() {
+  cleanup_proxy
+  cleanup_server
+}
+trap cleanup EXIT
+
+wait_ready() {
+  local port=$1
+  for i in $(seq 1 900); do
+    if curl -fsS "http://127.0.0.1:$port/v1/models" >/dev/null 2>&1; then
+      echo "ready port=$port after ${i}s"
+      return 0
+    fi
+    sleep 1
+  done
+  echo "ERROR: port $port did not become ready" >&2
+  return 1
+}
+
+build_image() {
+  (
+    cd "$ATLAS_DIR"
+    git rev-parse HEAD > "$OUT/source_git_head.txt" 2>&1 || true
+    git status --short > "$OUT/source_git_status.txt" 2>&1 || true
+    git diff --stat > "$OUT/source_git_diff_stat.txt" 2>&1 || true
+    local build_cmd=(docker build --target "$DOCKER_TARGET" -f docker/gb10/qwen3.6-27b/nvfp4/Dockerfile -t "$IMAGE" .)
+    printf '%q ' "${build_cmd[@]}" > "$OUT/cmds/docker_build.sh"
+    echo >> "$OUT/cmds/docker_build.sh"
+    "${build_cmd[@]}" 2>&1 | tee "$OUT/logs/docker_build.log"
+  )
+}
