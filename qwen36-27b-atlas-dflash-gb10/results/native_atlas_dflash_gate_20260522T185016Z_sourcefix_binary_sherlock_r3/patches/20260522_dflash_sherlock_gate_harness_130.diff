+    if [[ -n "${ATLAS_DFLASH_ADAPTIVE_BOOTSTRAP_MIN_ACCEPT:-}" ]]; then
+      envs+=(-e "ATLAS_DFLASH_ADAPTIVE_BOOTSTRAP_MIN_ACCEPT=$ATLAS_DFLASH_ADAPTIVE_BOOTSTRAP_MIN_ACCEPT")
+    fi
+    if [[ -n "${ATLAS_DFLASH_ADAPTIVE_BOOTSTRAP_COOLDOWN_TOKENS:-}" ]]; then
+      envs+=(-e "ATLAS_DFLASH_ADAPTIVE_BOOTSTRAP_COOLDOWN_TOKENS=$ATLAS_DFLASH_ADAPTIVE_BOOTSTRAP_COOLDOWN_TOKENS")
+    fi
+    dflash_args=(
+      --dflash
+      --draft-model "$DRAFT_PATH"
