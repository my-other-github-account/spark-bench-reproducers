+  wait_ready "$PORT"
+  docker logs "$SERVER_CONTAINER" > "$server_log" 2>&1 || true
+  grep -E "DFlash|BlockDiffusionDraftHead|RoPE|ctx_window|target_layers|fast K|K=gamma" "$server_log" || true
+}
+
+run_diverse() {
+  local mode=$1
+  local out_dir="$OUT/receipts/${mode}_diverse"
+  mkdir -p "$out_dir"
+  printf '%q ' python3 "$ROOT/scripts/atlas_http_bench.py" --host 127.0.0.1 --port "$PORT" \
+    --mode "native_atlas_${mode}_diverse" --runs "$RUNS" --max-tokens "$TG" \
+    --thinking-budget "$THINKING_BUDGET" --rows $DIVERSE_ROWS --output-dir "$out_dir" \
+    > "$OUT/cmds/${mode}_diverse.sh"
