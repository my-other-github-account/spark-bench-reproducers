-    print(json.dumps(summary, indent=2, sort_keys=True))
-    return 0 if summary["gate_pass"] else 2
+  fi
+
+  {
+    printf '%q ' docker run -d --name "$SERVER_CONTAINER" --gpus all --ipc=host --network host \
+      --entrypoint "$SPARK_BIN" \
+      "${envs[@]}" -v "$MODELS_DIR:$MODELS_DIR:ro" -v "$ROOT:$ROOT" "$IMAGE" \
+      serve \
+      --model-from-path "$MODEL_PATH" --model-name "$MODEL_NAME" --port "$PORT" \
+      --max-seq-len "$MAX_SEQ_LEN" --kv-cache-dtype bf16 \
+      --gpu-memory-utilization "$GPU_UTIL" --max-num-seqs 1 --max-batch-size 1 \
+      --max-prefill-tokens 0 "${dflash_args[@]}"
+    echo
+  } > "$OUT/cmds/launch_${mode}.sh"
+
+  docker run -d --name "$SERVER_CONTAINER" --gpus all --ipc=host --network host \
+    --entrypoint "$SPARK_BIN" \
+    "${envs[@]}" \
+    -v "$MODELS_DIR:$MODELS_DIR:ro" \
+    -v "$ROOT:$ROOT" \
+    "$IMAGE" \
+    serve \
+    --model-from-path "$MODEL_PATH" \
+    --model-name "$MODEL_NAME" \
+    --port "$PORT" \
+    --max-seq-len "$MAX_SEQ_LEN" \
+    --kv-cache-dtype bf16 \
+    --gpu-memory-utilization "$GPU_UTIL" \
+    --max-num-seqs 1 \
+    --max-batch-size 1 \
+    --max-prefill-tokens 0 \
+    "${dflash_args[@]}" > "$OUT/${mode}_container_id.txt"
