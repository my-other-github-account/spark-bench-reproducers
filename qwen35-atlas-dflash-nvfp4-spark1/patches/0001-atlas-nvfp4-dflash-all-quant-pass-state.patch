index 0000000..33ffe6a
--- /dev/null
+++ b/crates/spark-model/src/layers/dflash_head/cache.rs
@@ -0,0 +1,319 @@
+// SPDX-License-Identifier: AGPL-3.0-only
+
+//! DFlash committed-context KV-cache helpers.
+//!
+//! The Python/MLX reference only feeds newly accepted target-hidden rows on
+//! each step and relies on the drafter KV cache to carry the historical
+//! prefix. Atlas's earlier full-prefix recompute path was both slower and
+//! more acceptance-fragile on real prompts. These helpers upload the
+//! committed prefix incrementally into the existing per-drafter paged cache.
+
+use anyhow::Result;
+use std::time::Instant;
+
+use super::{BlockDiffusionDraftHead, DflashProposerState};
+use crate::layer::ForwardContext;
+use crate::layers::ops;
+
+impl BlockDiffusionDraftHead {
+    fn ensure_dflash_blocks(
+        &self,
+        dstate: &mut DflashProposerState,
+        required_positions: usize,
+    ) -> Result<()> {
+        let mut kv_cache = self.kv_cache.lock();
+        let bs = kv_cache.block_size();
+        let blocks_needed = required_positions.max(1).div_ceil(bs);
+        while dstate.block_table.len() < blocks_needed {
+            dstate.block_table.push(kv_cache.alloc_block()?);
+        }
+        Ok(())
+    }
+
+    fn upload_dflash_block_table(
+        &self,
+        dstate: &DflashProposerState,
+        ctx: &ForwardContext,
+        stream: u64,
+    ) -> Result<()> {
+        if dstate.block_table.is_empty() {
+            return Ok(());
+        }
+        let bt_bytes: Vec<u8> = dstate
+            .block_table
+            .iter()
+            .flat_map(|&b| (b as i32).to_le_bytes())
+            .collect();
+        ctx.gpu
+            .copy_h2d_async(&bt_bytes, self.scratch.block_table_dev, stream)?;
+        Ok(())
+    }
+
+    fn upload_dflash_slot_mapping(
+        &self,
+        dstate: &DflashProposerState,
+        start_pos: usize,
+        num_tokens: usize,
+        ctx: &ForwardContext,
+        stream: u64,
+    ) -> Result<()> {
+        if num_tokens == 0 {
+            return Ok(());
+        }
+        let bs = self.kv_cache.lock().block_size();
+        let slots_bytes: Vec<u8> = (start_pos..start_pos + num_tokens)
+            .flat_map(|pos| {
+                let block_idx = dstate.block_table[pos / bs] as i64;
+                let slot = block_idx * (bs as i64) + ((pos % bs) as i64);
+                slot.to_le_bytes()
+            })
+            .collect();
+        ctx.gpu
+            .copy_h2d_async(&slots_bytes, self.scratch.slot_mapping, stream)?;
+        Ok(())
+    }
+
+    pub(super) fn sync_ctx_prefix_to_cache(
+        &self,
+        dstate: &mut DflashProposerState,
+        ctx: &ForwardContext,
+        stream: u64,
+    ) -> Result<()> {
+        let t_total = Instant::now();
+        let ctx_off = std::env::var("ATLAS_DFLASH_DEBUG_CTX_OFF").ok().as_deref() == Some("1");
+        let seq_len_before_clamp = dstate.seq_len;
+        if ctx_off {
+            dstate.seq_len = 0;
+        } else if dstate.ctx_len < dstate.seq_len {
+            dstate.seq_len = dstate.ctx_len;
+        }
+
+        Self::trace_json(serde_json::json!({
+            "event": "ctx_cache_sync_start",
+            "seq_len_before": seq_len_before_clamp,
+            "seq_len_after_clamp": dstate.seq_len,
+            "ctx_len": dstate.ctx_len,
+            "gamma": self.gamma,
+            "ctx_off": ctx_off,
+        }));
+
+        let required_positions = if ctx_off {
+            self.gamma
+        } else {
+            dstate.ctx_len.saturating_add(self.gamma)
+        };
+        self.ensure_dflash_blocks(dstate, required_positions)?;
+        self.upload_dflash_block_table(dstate, ctx, stream)?;
+
+        if ctx_off {
+            Self::trace_json(serde_json::json!({
+                "event": "ctx_cache_sync_done",
+                "seq_len": dstate.seq_len,
+                "ctx_len": dstate.ctx_len,
+                "uploaded_rows": 0,
+                "ctx_off": true,
+            }));
+            return Ok(());
+        }
+
+        if dstate.seq_len >= dstate.ctx_len {
+            Self::trace_json(serde_json::json!({
+                "event": "ctx_cache_sync_done",
+                "seq_len": dstate.seq_len,
+                "ctx_len": dstate.ctx_len,
+                "uploaded_rows": 0,
+                "ctx_off": false,
+            }));
+            return Ok(());
+        }
+
+        let bf16 = 2usize;
+        let target_hidden_dim = self.target_layer_ids.len() * self.target_hidden_size;
+        let h = self.hidden_size as u32;
+        let kv_dim = (self.num_kv_heads * self.head_dim) as u32;
+        let q_dim = (self.num_q_heads * self.head_dim) as usize;
+        let kv_stride = self.num_kv_heads as u32 * self.head_dim as u32;
+        let chunk_cap = self.ctx_window.max(1);
+        let kv_info = {
+            let kv_cache = self.kv_cache.lock();
+            (
+                kv_cache.block_size() as u32,
+                kv_cache.cache_stride() as u64,
+                (0..self.layers.len())
+                    .map(|layer_idx| {
+                        (
+                            kv_cache.k_pool_ptr(layer_idx),
+                            kv_cache.v_pool_ptr(layer_idx),
+                        )
+                    })
+                    .collect::<Vec<_>>(),
+            )
+        };
+        let (cache_block_size, cache_stride, cache_ptrs) = kv_info;
+
+        let mut chunk_start = dstate.seq_len;
+        let mut uploaded_rows = 0usize;
+        while chunk_start < dstate.ctx_len {
+            let t_chunk = Instant::now();
+            let chunk_rows = (dstate.ctx_len - chunk_start).min(chunk_cap);
+
+            Self::trace_json(serde_json::json!({
+                "event": "ctx_cache_sync_chunk",
+                "chunk_start": chunk_start,
+                "chunk_rows": chunk_rows,
+                "ctx_len": dstate.ctx_len,
+                "seq_len": dstate.seq_len,
+                "ctx_off": false,
+            }));
+
+            let src = dstate
+                .ctx_hidden_acc
+                .offset(chunk_start * dstate.ctx_slot_bytes);
+            let t_fc_proj = Instant::now();
+            ops::dense_gemm(
+                ctx.gpu,
+                self.kernels.dense_gemm,
+                src,
+                &self.fc,
+                self.scratch.fc_proj,
+                chunk_rows as u32,
+                h,
+                target_hidden_dim as u32,
+                stream,
+            )?;
+            let fc_proj_ms = t_fc_proj.elapsed().as_secs_f64() * 1000.0;
+
+            let t_hidden_norm = Instant::now();
+            ops::rms_norm(
+                ctx.gpu,
+                self.kernels.rms_norm,
+                self.scratch.fc_proj,
+                &self.hidden_norm,
+                self.scratch.fc_proj,
+                chunk_rows as u32,
+                h,
+                self.rms_norm_eps,
+                stream,
+            )?;
+            let hidden_norm_ms = t_hidden_norm.elapsed().as_secs_f64() * 1000.0;
+
+            let t_stage_inputs = Instant::now();
+            let pos_bytes: Vec<u8> = (chunk_start..chunk_start + chunk_rows)
+                .flat_map(|p| (p as i32).to_le_bytes())
+                .collect();
+            ctx.gpu
+                .copy_h2d_async(&pos_bytes, self.scratch.position_ids, stream)?;
+            self.upload_dflash_slot_mapping(dstate, chunk_start, chunk_rows, ctx, stream)?;
+            let stage_inputs_ms = t_stage_inputs.elapsed().as_secs_f64() * 1000.0;
+
+            let t_layers = Instant::now();
+            for (layer_idx, layer) in self.layers.iter().enumerate() {
+                ops::dense_gemm(
+                    ctx.gpu,
+                    self.kernels.dense_gemm,
+                    self.scratch.fc_proj,
+                    &layer.k_proj,
+                    self.scratch.k_buf,
+                    chunk_rows as u32,
+                    kv_dim,
+                    h,
+                    stream,
+                )?;
+                ops::dense_gemm(
+                    ctx.gpu,
+                    self.kernels.dense_gemm,
+                    self.scratch.fc_proj,
+                    &layer.v_proj,
+                    self.scratch.v_buf,
+                    chunk_rows as u32,
+                    kv_dim,
+                    h,
+                    stream,
+                )?;
+                ctx.gpu
+                    .memset_async(self.scratch.q_buf, 0, chunk_rows * q_dim * bf16, stream)?;
+                ops::rms_norm(
+                    ctx.gpu,
+                    self.kernels.rms_norm,
+                    self.scratch.k_buf,
+                    &layer.k_norm,
+                    self.scratch.k_buf,
+                    chunk_rows as u32 * self.num_kv_heads as u32,
+                    self.head_dim as u32,
+                    self.rms_norm_eps,
+                    stream,
+                )?;
+                ops::rope_yarn(
+                    ctx.gpu,
+                    self.kernels.rope_qwen3,
+                    self.scratch.q_buf,
+                    self.scratch.k_buf,
+                    self.scratch.position_ids,
+                    chunk_rows as u32,
+                    self.num_q_heads as u32,
+                    self.num_kv_heads as u32,
+                    self.head_dim as u32,
+                    self.rotary_dim as u32,
+                    self.yarn_inv_freq,
+                    self.rope_theta,
+                    stream,
+                )?;
+                let (k_pool, v_pool) = cache_ptrs[layer_idx];
+                ops::reshape_and_cache(
+                    ctx.gpu,
+                    self.kernels.reshape_cache,
+                    self.scratch.k_buf,
+                    self.scratch.v_buf,
+                    k_pool,
+                    v_pool,
+                    self.scratch.slot_mapping,
+                    chunk_rows as u32,
+                    self.num_kv_heads as u32,
+                    self.head_dim as u32,
+                    cache_block_size,
+                    kv_stride,
+                    kv_stride,
+                    cache_stride,
+                    stream,
+                )?;
+            }
+            let layers_kv_ms = t_layers.elapsed().as_secs_f64() * 1000.0;
+
+            Self::trace_json(serde_json::json!({
+                "event": "phase_timing",
+                "phase": "ctx_cache_sync_chunk",
+                "function": "BlockDiffusionDraftHead::sync_ctx_prefix_to_cache",
+                "file": "crates/spark-model/src/layers/dflash_head/cache.rs",
+                "chunk_start": chunk_start,
+                "chunk_rows": chunk_rows,
+                "fc_proj_ms": fc_proj_ms,
+                "hidden_norm_ms": hidden_norm_ms,
+                "stage_inputs_ms": stage_inputs_ms,
+                "layers_kv_ms": layers_kv_ms,
+                "total_ms": t_chunk.elapsed().as_secs_f64() * 1000.0,
+            }));
+
+            chunk_start += chunk_rows;
+            uploaded_rows += chunk_rows;
+        }
+
+        dstate.seq_len = dstate.ctx_len;
+        Self::trace_json(serde_json::json!({
+            "event": "phase_timing",
+            "phase": "ctx_cache_sync_total",
+            "function": "BlockDiffusionDraftHead::sync_ctx_prefix_to_cache",
+            "file": "crates/spark-model/src/layers/dflash_head/cache.rs",
+            "ctx_len": dstate.ctx_len,
+            "uploaded_rows": uploaded_rows,
+            "total_ms": t_total.elapsed().as_secs_f64() * 1000.0,
+        }));
+        Self::trace_json(serde_json::json!({
+            "event": "ctx_cache_sync_done",
+            "seq_len": dstate.seq_len,
+            "ctx_len": dstate.ctx_len,
+            "uploaded_rows": uploaded_rows,
+            "ctx_off": false,
+        }));
+        Ok(())
+    }
+}
