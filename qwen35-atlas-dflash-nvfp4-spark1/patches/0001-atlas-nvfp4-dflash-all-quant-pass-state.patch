 }
 
+/// GPU-side batched argmax over BF16 logits.
+///
+/// Processes `num_rows` contiguous `[vocab_size]` rows from `logits` and writes
+/// one u32 token ID per row into `out`.
+pub fn argmax_bf16_batch(
+    gpu: &dyn GpuBackend,
+    kernel: KernelHandle,
+    logits: DevicePtr,
+    out: DevicePtr,
+    num_rows: u32,
+    vocab_size: u32,
+    stream: u64,
+) -> Result<()> {
+    if num_rows == 0 {
+        return Ok(());
+    }
+    KernelLaunch::new(gpu, kernel)
+        .grid([num_rows, 1, 1])
+        .block([1024, 1, 1])
+        .arg_ptr(logits)
+        .arg_ptr(out)
+        .arg_u32(vocab_size)
+        .launch(stream)
+}
