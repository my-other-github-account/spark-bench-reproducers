 use super::*;
 
+fn env_truthy(value: Option<&str>) -> bool {
+    matches!(value, Some("1") | Some("true"))
+}
+
+fn resolve_f32_recurrent_decode_enabled(
+    default_enabled: bool,
+    enable_override: Option<&str>,
+    disable_override: Option<&str>,
+) -> bool {
+    if env_truthy(enable_override) {
+        true
+    } else if env_truthy(disable_override) {
+        false
+    } else {
+        default_enabled
+    }
+}
+
+pub(super) fn f32_recurrent_decode_enabled(default_enabled: bool) -> bool {
+    static OVERRIDE: std::sync::OnceLock<Option<bool>> = std::sync::OnceLock::new();
+    match OVERRIDE.get_or_init(|| {
+        let enable = std::env::var("ATLAS_SSM_ENABLE_F32_DECODE").ok();
+        let disable = std::env::var("ATLAS_SSM_DISABLE_F32_DECODE").ok();
+        if env_truthy(enable.as_deref()) && env_truthy(disable.as_deref()) {
+            tracing::warn!(
+                "Both ATLAS_SSM_ENABLE_F32_DECODE and ATLAS_SSM_DISABLE_F32_DECODE are set; preferring explicit enable"
+            );
+        }
+        if env_truthy(enable.as_deref()) {
+            Some(true)
+        } else if env_truthy(disable.as_deref()) {
+            Some(false)
+        } else {
+            None
+        }
+    }) {
+        Some(enabled) => *enabled,
+        None => {
+            resolve_f32_recurrent_decode_enabled(default_enabled, None, None)
+        }
+    }
+}
