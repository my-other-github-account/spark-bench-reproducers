+/// Official `Qwen/Qwen3.5-27B-FP8` style nested config:
+/// - top-level `model_type = qwen3_5`
+/// - dense hybrid text config under `text_config`
+/// - top-level `quantization_config.quant_method = "fp8"`
+/// - Hugging Face-native `modules_to_not_convert` list instead of
+///   Atlas/vLLM-style `ignore` / `exclude_modules`.
+#[test]
+fn test_parse_qwen35_fp8_nested_config_with_modules_to_not_convert() {
+    let json = r#"{
+        "model_type": "qwen3_5",
+        "architectures": ["Qwen3_5ForConditionalGeneration"],
+        "text_config": {
+            "model_type": "qwen3_5_text",
+            "hidden_size": 5120,
+            "num_hidden_layers": 64,
+            "num_attention_heads": 24,
+            "num_key_value_heads": 4,
+            "head_dim": 256,
+            "intermediate_size": 17408,
+            "partial_rotary_factor": 0.25,
+            "linear_num_key_heads": 16,
+            "linear_key_head_dim": 128,
+            "linear_num_value_heads": 48,
+            "linear_value_head_dim": 128,
+            "linear_conv_kernel_dim": 4,
+            "vocab_size": 248320,
+            "eos_token_id": 248044,
+            "full_attention_interval": 4,
+            "rope_parameters": {
+                "rope_theta": 10000000,
+                "rope_type": "default",
+                "partial_rotary_factor": 0.25,
+                "mrope_interleaved": true,
+                "mrope_section": [11, 11, 10]
+            }
+        },
+        "quantization_config": {
+            "quant_method": "fp8",
+            "weight_block_size": [128, 128],
+            "activation_scheme": "dynamic",
+            "modules_to_not_convert": [
+                "lm_head",
+                "model.language_model.embed_tokens",
+                "model.language_model.layers.0.linear_attn.conv1d",
+                "model.language_model.layers.0.linear_attn.in_proj_a",
+                "model.language_model.layers.0.linear_attn.in_proj_b"
+            ]
+        }
+    }"#;
+
+    let cfg = parse_config(json).unwrap();
+    assert_eq!(cfg.model_type, "qwen3_5");
+    assert!(cfg.is_qwen35_dense());
+    assert_eq!(cfg.hidden_size, 5120);
+    assert_eq!(cfg.num_hidden_layers, 64);
+    assert_eq!(cfg.num_experts, 0);
+    assert_eq!(cfg.vocab_size, 248320);
+    assert!(cfg.mrope_interleaved);
+    assert_eq!(cfg.mrope_section, [11, 11, 10]);
+
+    let qc = cfg
+        .quantization_config
+        .as_ref()
+        .expect("expected parsed quantization_config");
+    assert_eq!(qc.quant_method, "fp8");
+    assert!(
+        qc.ignore_modules.iter().any(|m| m == "lm_head"),
+        "modules_to_not_convert should be normalized into ignore_modules"
+    );
+    assert!(
+        qc.ignore_modules
+            .iter()
+            .any(|m| m == "model.language_model.layers.0.linear_attn.conv1d")
+    );
+}
