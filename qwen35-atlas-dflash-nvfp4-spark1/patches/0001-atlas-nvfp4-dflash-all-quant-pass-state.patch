+//! Contains the γ-block kernel chain (input_layernorm → q/k/v projections
+//! → q_norm/k_norm → RoPE → paged DFlash attention over cached prefix +
+//! transient γ-block K/V → o_proj → residual → post_attention_layernorm
+//! → MLP gate/up → silu_mul → down_proj → residual). Called once per
+//! drafter layer from `forward_block`.
 
 use anyhow::Result;
+use std::time::Instant;
 
 use super::{BlockDiffusionDraftHead, DflashLayer};
 use crate::layer::ForwardContext;
 
+fn run_single_or_batched_proj(
+    gpu: &dyn spark_runtime::gpu::GpuBackend,
+    kernels: &super::DflashKernels,
+    input: spark_runtime::gpu::DevicePtr,
+    dense_weight: &crate::weight_map::DenseWeight,
+    nvfp4_weight: Option<&crate::weight_map::QuantizedWeight>,
+    output: spark_runtime::gpu::DevicePtr,
+    rows: u32,
+    n: u32,
+    k: u32,
+    stream: u64,
+) -> Result<()> {
+    if let Some(weight) = nvfp4_weight {
+        match rows {
+            3 if kernels.w4a16_gemv_batch3.0 != 0 => {
+                return crate::layers::ops::w4a16_gemv_batch3(
+                    gpu,
+                    kernels.w4a16_gemv_batch3,
+                    input,
+                    weight,
+                    output,
+                    n,
+                    k,
+                    stream,
+                );
+            }
+            2 if kernels.w4a16_gemv_batch2.0 != 0 => {
+                return crate::layers::ops::w4a16_gemv_batch2(
+                    gpu,
+                    kernels.w4a16_gemv_batch2,
+                    input,
+                    weight,
+                    output,
+                    n,
+                    k,
+                    stream,
+                );
+            }
+            1 if kernels.w4a16_gemv.0 != 0 => {
+                return crate::layers::ops::w4a16_gemv(
+                    gpu,
+                    kernels.w4a16_gemv,
+                    input,
+                    weight,
+                    output,
+                    n,
+                    k,
+                    stream,
+                );
+            }
+            _ if kernels.w4a16_gemm.0 != 0 => {
+                return crate::layers::ops::w4a16_gemm(
+                    gpu,
+                    kernels.w4a16_gemm,
+                    input,
+                    weight,
+                    output,
+                    rows,
+                    n,
+                    k,
+                    stream,
+                );
+            }
+            _ => {}
+        }
+    }
+    crate::layers::ops::dense_gemm(
+        gpu,
+        kernels.dense_gemm,
+        input,
+        dense_weight,
+        output,
+        rows,
+        n,
+        k,
+        stream,
+    )
+}
