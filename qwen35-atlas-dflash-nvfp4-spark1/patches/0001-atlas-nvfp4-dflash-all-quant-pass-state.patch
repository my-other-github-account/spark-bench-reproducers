+        let mut logits_topk = Vec::with_capacity(rows_to_dump);
+        for row_idx in 0..rows_to_dump {
+            let logits_row = self
+                .scratch
+                .logits
+                .offset((row_idx + 1) * self.vocab_size * 2usize);
+            let mut row_buf = vec![0u8; self.vocab_size * 2usize];
