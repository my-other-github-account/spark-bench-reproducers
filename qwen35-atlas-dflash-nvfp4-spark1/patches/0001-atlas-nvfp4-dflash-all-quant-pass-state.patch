+extern "C" __global__ void argmax_bf16_batch(
+    const __nv_bfloat16* __restrict__ logits,
+    unsigned int* __restrict__ out,
+    unsigned int n
+) {
+    __shared__ float s_val[1024];
+    __shared__ unsigned int s_idx[1024];
+
+    const unsigned int tid = threadIdx.x;
+    const unsigned int stride = blockDim.x;
+    const unsigned int row = blockIdx.x;
+    const __nv_bfloat16* row_logits = logits + (static_cast<size_t>(row) * n);
+
+    float local_max = -1e30f;
+    unsigned int local_idx = 0;
+    for (unsigned int i = tid; i < n; i += stride) {
+        float v = __bfloat162float(row_logits[i]);
+        if (v > local_max) {
+            local_max = v;
+            local_idx = i;
+        }
+    }
+
+    s_val[tid] = local_max;
+    s_idx[tid] = local_idx;
+    __syncthreads();
+
+    for (unsigned int s = blockDim.x / 2; s > 0; s >>= 1) {
+        if (tid < s) {
+            if (s_val[tid + s] > s_val[tid]) {
+                s_val[tid] = s_val[tid + s];
+                s_idx[tid] = s_idx[tid + s];
+            }
+        }
+        __syncthreads();
+    }
+
+    if (tid == 0) {
+        out[row] = s_idx[0];
+    }
+}
