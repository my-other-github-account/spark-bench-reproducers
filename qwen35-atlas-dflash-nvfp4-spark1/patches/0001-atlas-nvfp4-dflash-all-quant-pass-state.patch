+    if !CUDA_PROFILE_STARTED.load(Ordering::Relaxed) {
+        return;
+    }
+    if CUDA_PROFILE_STOPPED
+        .compare_exchange(false, true, Ordering::Relaxed, Ordering::Relaxed)
+        .is_err()
+    {
+        return;
+    }
+    let result = unsafe { cuProfilerStop() };
+    if result == CUresult::CUDA_SUCCESS {
+        tracing::info!("CUDA profiler capture stopped ({reason})");
+    } else {
+        tracing::warn!("CUDA profiler capture stop failed ({reason}): {result:?}");
