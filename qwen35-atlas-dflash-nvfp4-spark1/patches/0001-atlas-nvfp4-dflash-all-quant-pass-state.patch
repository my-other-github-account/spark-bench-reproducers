+#[cfg(test)]
+mod tests {
+    use super::parse_quantization_config;
+
+    #[test]
+    fn parses_modules_to_not_convert_as_ignore_modules() {
+        let raw = serde_json::json!({
+            "quantization_config": {
+                "quant_method": "fp8",
+                "weight_block_size": [128, 128],
+                "modules_to_not_convert": [
+                    "lm_head",
+                    "model.language_model.embed_tokens"
+                ]
+            }
+        });
+
+        let parsed = parse_quantization_config(&raw).expect("quant config");
+        assert_eq!(parsed.quant_method, "fp8");
+        assert_eq!(
+            parsed.ignore_modules,
+            vec![
+                "lm_head".to_string(),
+                "model.language_model.embed_tokens".to_string()
+            ]
+        );
+    }
+}
