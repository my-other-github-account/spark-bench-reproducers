+            h0 = g0*h0 + smem_k0[j]  *v_new_0;
+            h1 = g0*h1 + smem_k0[j+1]*v_new_0;
+            h2 = g0*h2 + smem_k0[j+2]*v_new_0;
+            h3 = g0*h3 + smem_k0[j+3]*v_new_0;
