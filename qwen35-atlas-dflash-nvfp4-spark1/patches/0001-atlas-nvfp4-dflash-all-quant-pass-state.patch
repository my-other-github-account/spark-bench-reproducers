 use super::super::{ModelConfig, QuantizationConfig};
 
+fn extend_unique_string_list(dst: &mut Vec<String>, arr: Option<&Vec<Value>>) {
+    let Some(arr) = arr else {
+        return;
+    };
+    for v in arr {
+        if let Some(s) = v.as_str()
+            && !dst.iter().any(|existing| existing == s)
