+            let mut best: Vec<(usize, f32)> = Vec::with_capacity(topk);
+            for tok in 0..self.vocab_size {
+                let off = tok * 2usize;
+                let bits = u16::from_le_bytes([row_buf[off], row_buf[off + 1]]);
+                let val = f32::from_bits((bits as u32) << 16);
+                let insert_at = best
+                    .iter()
+                    .position(|&(_, best_val)| val > best_val)
+                    .unwrap_or(best.len());
+                if insert_at < topk {
+                    best.insert(insert_at, (tok, val));
+                    if best.len() > topk {
