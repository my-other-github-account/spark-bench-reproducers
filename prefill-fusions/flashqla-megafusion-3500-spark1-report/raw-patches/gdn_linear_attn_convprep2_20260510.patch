 logger = init_logger(__name__)
 
 
+@triton.jit
+def _fused_conv_post_conv_prep_kernel(
+    x_ptr,
+    w_ptr,
+    bias_ptr,
+    conv_state_ptr,
+    state_indices_ptr,
+    has_initial_state_ptr,
+    a_ptr,
+    b_ptr,
+    A_log_ptr,
+    dt_bias_ptr,
+    q_ptr,
+    k_ptr,
+    v_ptr,
+    g_ptr,
+    beta_ptr,
+    L,
+    stride_x_tok: tl.constexpr,
+    stride_x_dim: tl.constexpr,
+    stride_w_dim: tl.constexpr,
+    stride_w_width: tl.constexpr,
+    stride_cs_seq: tl.constexpr,
+    stride_cs_dim: tl.constexpr,
+    stride_cs_tok: tl.constexpr,
+    stride_a_tok: tl.constexpr,
+    stride_b_tok: tl.constexpr,
+    H: tl.constexpr,
+    HV: tl.constexpr,
+    K: tl.constexpr,
+    V: tl.constexpr,
+    WIDTH: tl.constexpr,
+    STATE_LEN: tl.constexpr,
+    BT: tl.constexpr,
+    BD: tl.constexpr,
+    SOFTPLUS_THRESHOLD: tl.constexpr,
+    HAS_BIAS: tl.constexpr,
+):
+    pid_t = tl.program_id(0)
+    pid_part = tl.program_id(1)
+    offs_t = pid_t * BT + tl.arange(0, BT)
+    offs_d = tl.arange(0, BD)
+    mask_t = offs_t < L
+
+    HK: tl.constexpr = H * K
+    V_OFFSET: tl.constexpr = 2 * H * K
+
+    is_q = pid_part < H
+    is_k = (pid_part >= H) & (pid_part < 2 * H)
+    qk_h = tl.where(is_q, pid_part, pid_part - H)
+    hv_h = pid_part - 2 * H
+    feat_base = tl.where(is_q, qk_h * K, tl.where(is_k, HK + qk_h * K, V_OFFSET + hv_h * V))
+    feat = feat_base + offs_d
+    mask_d = tl.where(pid_part < 2 * H, offs_d < K, offs_d < V)
+
+    state_idx = tl.load(state_indices_ptr + 0).to(tl.int64)
+    load_init = tl.load(has_initial_state_ptr + 0).to(tl.int1)
+
+    if HAS_BIAS:
+        acc = tl.load(bias_ptr + feat, mask=mask_d, other=0.0).to(tl.float32)
+    else:
+        acc = tl.zeros((BT, BD), dtype=tl.float32)
+    for j in tl.static_range(0, WIDTH):
+        rel_t = offs_t + j - STATE_LEN
+        wv = tl.load(w_ptr + feat * stride_w_dim + j * stride_w_width, mask=mask_d, other=0.0).to(tl.float32)
+        x_cur = tl.load(
+            x_ptr + rel_t[:, None] * stride_x_tok + feat[None, :] * stride_x_dim,
+            mask=(rel_t[:, None] >= 0) & mask_t[:, None] & mask_d[None, :],
+            other=0.0,
+        ).to(tl.float32)
+        cs_pos = STATE_LEN + rel_t
+        x_prev = tl.load(
+            conv_state_ptr
+            + state_idx * stride_cs_seq
+            + feat[None, :] * stride_cs_dim
+            + cs_pos[:, None] * stride_cs_tok,
+            mask=(rel_t[:, None] < 0) & (cs_pos[:, None] >= 0) & load_init & mask_t[:, None] & mask_d[None, :],
+            other=0.0,
+        ).to(tl.float32)
+        xv = tl.where(rel_t[:, None] >= 0, x_cur, x_prev)
+        acc += xv * wv[None, :]
+
+    acc = acc / (1.0 + tl.exp(-acc))
+
+    if pid_part < 2 * H:
+        sq = tl.sum(acc * acc, axis=1)
+        inv = 1.0 / tl.sqrt(sq + 1.0e-6)
+        out = acc * inv[:, None]
+        out_offsets = offs_t[:, None] * (H * K) + qk_h * K + offs_d[None, :]
+        if is_q:
+            tl.store(q_ptr + out_offsets, out, mask=mask_t[:, None] & mask_d[None, :])
+        else:
+            tl.store(k_ptr + out_offsets, out, mask=mask_t[:, None] & mask_d[None, :])
+    else:
+        v_offsets = offs_t[:, None] * (HV * V) + hv_h * V + offs_d[None, :]
+        tl.store(v_ptr + v_offsets, acc, mask=mask_t[:, None] & mask_d[None, :])
+        A_log_val = tl.load(A_log_ptr + hv_h).to(tl.float32)
+        dt_bias_val = tl.load(dt_bias_ptr + hv_h).to(tl.float32)
+        av = tl.load(a_ptr + offs_t * stride_a_tok + hv_h, mask=mask_t, other=0.0).to(tl.float32)
+        bv = tl.load(b_ptr + offs_t * stride_b_tok + hv_h, mask=mask_t, other=0.0).to(tl.float32)
+        xg = av + dt_bias_val
+        sp = tl.where(xg > 0, xg + tl.log(1.0 + tl.exp(-xg)), tl.log(1.0 + tl.exp(xg)))
+        sp = tl.where(xg <= SOFTPLUS_THRESHOLD, sp, xg)
+        gv = -tl.exp(A_log_val) * sp
+        betav = tl.sigmoid(bv)
+        gb_offsets = offs_t * HV + hv_h
+        tl.store(g_ptr + gb_offsets, gv, mask=mask_t)
+        tl.store(beta_ptr + gb_offsets, betav, mask=mask_t)
+
+    last_start = L - STATE_LEN
+    if pid_t == tl.cdiv(L, BT) - 1:
+        for st in tl.static_range(0, STATE_LEN):
+            src_t = last_start + st
+            raw = tl.load(
+                x_ptr + src_t * stride_x_tok + feat * stride_x_dim,
+                mask=(src_t >= 0) & mask_d,
+                other=0.0,
+            )
+            tl.store(
+                conv_state_ptr + state_idx * stride_cs_seq + feat * stride_cs_dim + st * stride_cs_tok,
+                raw,
+                mask=mask_d,
+            )
+
+
+def fused_conv_post_conv_prep(
+    mixed_qkv: torch.Tensor,
+    conv_weights: torch.Tensor,
+    conv_bias: torch.Tensor,
+    conv_state: torch.Tensor,
+    state_indices: torch.Tensor,
+    has_initial_state: torch.Tensor,
+    a: torch.Tensor,
+    b: torch.Tensor,
+    A_log: torch.Tensor,
+    dt_bias: torch.Tensor,
+    num_k_heads: int,
+    head_k_dim: int,
+    head_v_dim: int,
+):
+    L = mixed_qkv.shape[0]
+    H = num_k_heads
+    K = head_k_dim
+    V = head_v_dim
+    HV = A_log.shape[0]
+    assert mixed_qkv.shape[1] == 2 * H * K + HV * V
+    q = torch.empty((L, H, K), dtype=mixed_qkv.dtype, device=mixed_qkv.device)
+    k = torch.empty((L, H, K), dtype=mixed_qkv.dtype, device=mixed_qkv.device)
+    v = torch.empty((L, HV, V), dtype=mixed_qkv.dtype, device=mixed_qkv.device)
+    g = torch.empty((L, HV), dtype=torch.float32, device=mixed_qkv.device)
+    beta = torch.empty((L, HV), dtype=torch.float32, device=mixed_qkv.device)
+    if L == 0:
+        return q, k, v, g, beta
+    width = conv_weights.shape[1]
+    grid = (triton.cdiv(L, 16), 2 * H + HV)
+    _fused_conv_post_conv_prep_kernel[grid](
+        mixed_qkv,
+        conv_weights,
+        conv_bias if conv_bias is not None else mixed_qkv,
+        conv_state,
+        state_indices,
+        has_initial_state,
+        a,
+        b,
+        A_log,
+        dt_bias,
+        q,
+        k,
+        v,
+        g,
+        beta,
+        L,
+        stride_x_tok=mixed_qkv.stride(0),
+        stride_x_dim=mixed_qkv.stride(1),
+        stride_w_dim=conv_weights.stride(0),
+        stride_w_width=conv_weights.stride(1),
+        stride_cs_seq=conv_state.stride(0),
+        stride_cs_dim=conv_state.stride(1),
+        stride_cs_tok=conv_state.stride(2),
+        stride_a_tok=a.stride(0),
+        stride_b_tok=b.stride(0),
+        H=H,
+        HV=HV,
+        K=K,
+        V=V,
+        WIDTH=width,
+        STATE_LEN=width - 1,
+        BT=16,
+        BD=triton.next_power_of_2(max(K, V)),
+        SOFTPLUS_THRESHOLD=20.0,
+        HAS_BIAS=conv_bias is not None,
+        num_warps=4,
+        num_stages=2,
+    )
+    return q, k, v, g, beta
+
